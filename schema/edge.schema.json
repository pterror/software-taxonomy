{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhi.zone/software-taxonomy/schema/edge.schema.json",
  "title": "Edge",
  "type": "object",
  "required": ["from", "to", "kind"],
  "additionalProperties": false,
  "properties": {
    "from": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Source species id."
    },
    "to": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Target species id."
    },
    "kind": {
      "type": "string",
      "enum": [
        "direct_descent",
        "forked_from",
        "influenced_by",
        "convergent_trait",
        "hybridization",
        "parasitism",
        "symbiosis",
        "mimicry",
        "competitive_displacement",
        "extinct_replaced_by"
      ]
    },
    "year": {
      "type": "string",
      "description": "Year of the relationship, as a string (e.g. '1983')."
    },
    "year_range": {
      "type": "string",
      "description": "Year range (e.g. '1989-1995')."
    },
    "trait": {
      "type": "string",
      "description": "Specific trait involved (for convergent_trait edges)."
    },
    "note": {
      "type": "string"
    }
  }
}
