{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhi.zone/software-taxonomy/schema/species.schema.json",
  "title": "Species",
  "type": "object",
  "required": ["id", "name", "clade"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clade": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Most-specific clade id."
    },
    "first_released": {
      "type": "string",
      "description": "ISO date (YYYY-MM-DD) or year string (YYYY)."
    },
    "extinct": {
      "oneOf": [
        { "type": "string", "description": "ISO date of discontinuation." },
        { "type": "null" }
      ]
    },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "developers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "principal_authors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "birthplace": {
          "type": "string"
        }
      }
    },
    "habitat": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "license": {
          "type": "string"
        },
        "deployment": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metabolism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "energy_source": {
          "type": "string"
        }
      }
    },
    "features": {
      "type": "object",
      "description": "Open featureset — keys vary by clade. Intentionally unconstrained."
    },
    "morphology": {
      "type": "object",
      "description": "Open morphology — keys vary by clade. Intentionally unconstrained."
    },
    "size_class": {
      "type": "string"
    },
    "wikipedia": {
      "type": "string",
      "description": "Wikipedia article slug (the part after /wiki/)."
    },
    "official_url": {
      "type": "string",
      "format": "uri"
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "string"
    }
  }
}
