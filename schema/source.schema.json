{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhi.zone/software-taxonomy/schema/source.schema.json",
  "title": "Source",
  "type": "object",
  "required": ["id", "kind", "title", "url"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique source id, e.g. 'wp:Microsoft_Word@1234567890'."
    },
    "kind": {
      "type": "string",
      "enum": ["wikipedia", "official", "paper", "book", "personal_communication", "interpretive", "other"],
      "description": "Source type."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "revid": {
      "type": "integer",
      "minimum": 1,
      "description": "Wikipedia revision id."
    },
    "fetched": {
      "type": "string",
      "description": "ISO date when the source was fetched."
    },
    "last_verified": {
      "type": "string",
      "description": "ISO date when the source was last manually re-checked against the underlying citation."
    }
  },
  "if": {
    "properties": {"kind": {"const": "wikipedia"}}
  },
  "then": {
    "required": ["revid"]
  },
  "else": {
    "if": {
      "properties": {"kind": {"const": "official"}}
    },
    "then": {
      "required": ["last_verified"]
    },
    "else": {
      "if": {
        "properties": {"kind": {"const": "interpretive"}}
      },
      "then": {
        "required": ["last_verified"]
      }
    }
  }
}
