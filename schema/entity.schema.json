{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhi.zone/software-taxonomy/schema/entity.schema.json",
  "title": "Entity",
  "type": "object",
  "required": ["id", "labels", "statements"],
  "additionalProperties": false,
  "$defs": {
    "StatementEntry": {
      "type": "object",
      "required": ["value"],
      "additionalProperties": false,
      "properties": {
        "value": {
          "oneOf": [
            {"type": "string"},
            {"type": "number"},
            {"type": "boolean"}
          ]
        },
        "source": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9:_@.-]*$"
        },
        "qualifiers": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {"type": "string"},
              {"type": "number"},
              {"type": "boolean"}
            ]
          }
        },
        "rank": {
          "type": "string",
          "enum": ["preferred", "normal", "deprecated"]
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique entity id in kebab-case."
    },
    "labels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string"},
      "description": "Human-readable labels keyed by BCP-47 language code."
    },
    "aliases": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Alternative names or abbreviations."
    },
    "description": {
      "type": "string",
      "description": "Short one-sentence description."
    },
    "statements": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"$ref": "#/$defs/StatementEntry"}
      },
      "description": "Predicate-keyed map of statement arrays."
    }
  }
}
