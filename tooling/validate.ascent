// Software Taxonomy — Datalog invariant rules
// Facts are emitted by tooling/src/lib/datalog.ts from the loaded lens set.
// Violations are parsed from this program's stdout relation output.
//
// Fact schema (emitted by datalog.ts):
//   entity(id, owner_lens)
//   entity_ref(subject, predicate, target_id, rank)  — entity-valued stmts; target_id has @ stripped
//   stmt(subject, predicate, value, rank)             — all stmts (non-deprecated); value: string repr
//   stmt_src(subject, predicate, rank, source)        — source for stmts that have one
//   is_sentinel(subject, predicate, rank_value_key)   — marks sentinel-valued stmts
//   predicate_def(id, value_type, card_min, card_max, expect_preferred, lens_id)
//     card_min: i32, card_max: i32 (-1 = unbounded)
//     expect_preferred: "true" or "false"
//   predicate_domain(predicate_id, class_id)
//   predicate_range(predicate_id, class_id)
//   predicate_alias(alias_id, canonical_id)
//   source_def(id, lens_id)
//   lens(id, register, source_required)              — source_required: "true"/"false"
//   entity_owner(entity_id, owner_lens_id, source_required)
//
// To add a new invariant: declare an output relation and write a rule below.
// Run manually: cat facts.dl validate.ascent | ascent-interpreter /dev/stdin

// ── Input relations ───────────────────────────────────────────────────────────

relation entity(String, String);
relation entity_def(String, String, String);
relation entity_ref(String, String, String, String);
relation stmt(String, String, String, String);
relation stmt_src(String, String, String, String);
relation is_sentinel(String, String, String);
relation predicate_def(String, String, i32, i32, String, String);
relation predicate_domain(String, String);
relation predicate_range(String, String);
relation predicate_alias(String, String);
relation source_def(String, String);
relation lens(String, String, String);
relation entity_owner(String, String, String);
relation stmt_rank(String, String, String, String);
relation has_qualifier(String, String, String, String);
relation qualifier_entity_ref(String, String, String, String, String);

// ── Derived: transitive class hierarchy ──────────────────────────────────────

relation subclass_of(String, String);
subclass_of(c, p) <-- entity_ref(c, "subclass_of", p, _);

relation transitive_subclass_of(String, String);
transitive_subclass_of(c, p) <-- subclass_of(c, p);
transitive_subclass_of(c, p) <-- subclass_of(c, m), transitive_subclass_of(m, p);

relation instance_of_direct(String, String);
instance_of_direct(e, c) <-- entity_ref(e, "instance_of", c, _);

relation transitive_instance_of(String, String);
transitive_instance_of(e, c) <-- instance_of_direct(e, c);
transitive_instance_of(e, c) <-- transitive_instance_of(e, m), transitive_subclass_of(m, c);

// ── Violation: duplicate_entity_id ───────────────────────────────────────────
// Fires when the same entity id appears in two different lenses (cross-lens duplicate).
// Also fires for same-lens duplicates via entity_def which includes line numbers.

relation duplicate_entity_id(String, String, String);
// Cross-lens: two different lenses define the same entity id
duplicate_entity_id(x, l1, l2) <-- entity_def(x, l1, _), entity_def(x, l2, _), if l1 < l2;
// Same-lens: two definitions with same lens but different lines
duplicate_entity_id(x, l, ln2) <-- entity_def(x, l, ln1), entity_def(x, l, ln2), if ln1 < ln2;

// ── Violation: dangling_entity_ref ───────────────────────────────────────────

relation dangling_entity_ref(String, String, String);
dangling_entity_ref(x, p, t) <-- entity_ref(x, p, t, _), !entity(t, _);

// ── Violation: dangling_source_ref ───────────────────────────────────────────

relation dangling_source_ref(String, String, String);
dangling_source_ref(x, p, s) <-- stmt_src(x, p, _, s), !source_def(s, _);

// ── Derived: class membership ─────────────────────────────────────────────────

// is_class: entities that are instances of meta:class (directly or transitively)
relation is_class(String);
is_class(x) <-- transitive_instance_of(x, "meta:class");
// meta:class itself is a class
is_class("meta:class");

// ── Derived: all non-deprecated statement uses ────────────────────────────────

// has_stmt(x, p): entity x uses predicate p in at least one non-deprecated statement
relation has_stmt(String, String);
has_stmt(x, p) <-- entity_ref(x, p, _, rank), if rank != "deprecated";
has_stmt(x, p) <-- stmt(x, p, _, rank), if rank != "deprecated";

// ── Violation: domain_violation ──────────────────────────────────────────────
// An entity uses a predicate without satisfying any of its domain classes.
// Exception: instance_of and subclass_of on class entities are structural (no domain check).

// domain_ok(x, p): entity x satisfies at least one domain class of predicate p
relation domain_ok(String, String);
domain_ok(x, p) <-- predicate_domain(p, d), transitive_instance_of(x, d);

relation domain_violation(String, String);
// Non-class entities: any predicate with domain that fails
domain_violation(x, p) <--
  has_stmt(x, p),
  predicate_domain(p, _),
  !domain_ok(x, p),
  !is_class(x);
// Class entities: only non-structural predicates (instance_of/subclass_of exempt)
domain_violation(x, p) <--
  has_stmt(x, p),
  predicate_domain(p, _),
  !domain_ok(x, p),
  is_class(x),
  if p != "instance_of",
  if p != "subclass_of";

// ── Violation: range_violation ───────────────────────────────────────────────
// A target entity (entity ref) does not satisfy the range class of the predicate.
// Exception: deprecated statements skip range check.
// Only fires for resolvable entity refs (dangling handled by dangling_entity_ref).

relation range_ok(String, String, String);
range_ok(x, p, t) <-- entity_ref(x, p, t, _), predicate_range(p, r), transitive_instance_of(t, r);

relation range_violation(String, String, String);
range_violation(x, p, t) <--
  entity_ref(x, p, t, rank),
  if rank != "deprecated",
  predicate_range(p, _),
  !range_ok(x, p, t),
  entity(t, _);

// ── Derived: active statements (non-deprecated) ───────────────────────────────

// active_entity_ref: non-deprecated entity refs
relation active_entity_ref(String, String, String, String);
active_entity_ref(x, p, t, r) <-- entity_ref(x, p, t, r), if r != "deprecated";

// active_stmt: non-deprecated scalar stmts (non-entity-ref stmts)
relation active_scalar_stmt(String, String, String, String);
active_scalar_stmt(x, p, v, r) <-- stmt(x, p, v, r), if r != "deprecated";

// active_real_stmt: non-deprecated, non-sentinel stmts (for cardinality min count)
relation active_real_scalar(String, String, String, String);
active_real_scalar(x, p, v, r) <-- active_scalar_stmt(x, p, v, r), if v != "__sentinel__";

// ── Violation: multi_preferred ───────────────────────────────────────────────
// More than one non-deprecated statement with rank=preferred for (entity, predicate).
// Uses merged statements (definition + extensions combined).

// Count preferred entity refs per (entity, predicate)
relation preferred_entity_ref_count(String, String, i32);
preferred_entity_ref_count(x, p, c) <--
  active_entity_ref(x, p, _, _),
  agg c = count() in active_entity_ref(x, p, _, "preferred");

// Count preferred scalar stmts per (entity, predicate)
relation preferred_scalar_count(String, String, i32);
preferred_scalar_count(x, p, c) <--
  active_scalar_stmt(x, p, _, _),
  agg c = count() in active_scalar_stmt(x, p, _, "preferred");

// multi_preferred: for non-instance_of predicates
relation multi_preferred(String, String);
multi_preferred(x, p) <-- preferred_entity_ref_count(x, p, c), if c > 1, if p != "instance_of";
multi_preferred(x, p) <-- preferred_scalar_count(x, p, c), if c > 1, if p != "instance_of";

// multi_preferred_instance_of: special case
relation multi_preferred_instance_of(String);
multi_preferred_instance_of(x) <-- preferred_entity_ref_count(x, "instance_of", c), if c > 1;

// ── Violation: no_preferred_rank ─────────────────────────────────────────────
// 2+ non-deprecated statements, no preferred rank, predicate has expect_preferred:true.

// Total active counts per (entity, predicate)
relation active_entity_ref_count(String, String, i32);
active_entity_ref_count(x, p, c) <--
  active_entity_ref(x, p, _, _),
  agg c = count() in active_entity_ref(x, p, _, _);

relation active_scalar_count(String, String, i32);
active_scalar_count(x, p, c) <--
  active_scalar_stmt(x, p, _, _),
  agg c = count() in active_scalar_stmt(x, p, _, _);

// expect_preferred predicates
relation expect_preferred_pred(String);
expect_preferred_pred(p) <-- predicate_def(p, _, _, _, "true", _);

// no_preferred_rank: fires when 2+ active stmts, no preferred, predicate expects preferred
// For entity-ref predicates
relation no_preferred_rank(String, String);
no_preferred_rank(x, p) <--
  active_entity_ref_count(x, p, c), if c >= 2,
  preferred_entity_ref_count(x, p, pc), if pc == 0,
  expect_preferred_pred(p),
  if p != "instance_of";

// For scalar predicates
no_preferred_rank(x, p) <--
  active_scalar_count(x, p, c), if c >= 2,
  preferred_scalar_count(x, p, pc), if pc == 0,
  expect_preferred_pred(p);

// multi-class-no-preferred-rank (instance_of specific): warning not error
// Reuse no_preferred_rank with instance_of special case
no_preferred_rank(x, "instance_of") <--
  active_entity_ref_count(x, "instance_of", c), if c >= 2,
  preferred_entity_ref_count(x, "instance_of", pc), if pc == 0;

// ── Violation: cardinality ────────────────────────────────────────────────────
// cardinality_violation_min: real (non-sentinel) count < min
// cardinality_violation_max: total (including sentinel) count > max

// Count real (non-sentinel) values per (entity, predicate)
relation real_entity_ref_count(String, String, i32);
real_entity_ref_count(x, p, c) <--
  active_entity_ref(x, p, _, _),
  agg c = count() in active_entity_ref(x, p, _, _);
// entity refs are never sentinels, so real_count = active_count

relation real_scalar_count(String, String, i32);
real_scalar_count(x, p, c) <--
  active_real_scalar(x, p, _, _),
  agg c = count() in active_real_scalar(x, p, _, _);

// Entities with a given predicate defined (via any statement, including deprecated)
relation entity_uses_pred(String, String);
entity_uses_pred(x, p) <-- entity_ref(x, p, _, _);
entity_uses_pred(x, p) <-- stmt(x, p, _, _);

// Combined real count: entity_refs are always real; scalars count only non-sentinels
// For predicates with entity value_type, only entity_refs count
// For other predicates, only scalars count
// We split by value_type

relation pred_is_entity_type(String);
pred_is_entity_type(p) <-- predicate_def(p, "entity", _, _, _, _);

// Real count for entity-type predicates
relation real_count_entity_pred(String, String, i32);
real_count_entity_pred(x, p, c) <--
  entity_uses_pred(x, p),
  pred_is_entity_type(p),
  real_entity_ref_count(x, p, c);

// Zero real count for entity-type predicates with no entity_refs (only sentinels in stmt)
real_count_entity_pred(x, p, 0) <--
  entity_uses_pred(x, p),
  pred_is_entity_type(p),
  !active_entity_ref(x, p, _, _);

// Real count for non-entity-type predicates
relation real_count_scalar_pred(String, String, i32);
real_count_scalar_pred(x, p, c) <--
  entity_uses_pred(x, p),
  !pred_is_entity_type(p),
  real_scalar_count(x, p, c);

real_count_scalar_pred(x, p, 0) <--
  entity_uses_pred(x, p),
  !pred_is_entity_type(p),
  !active_real_scalar(x, p, _, _);

// Total count (for max check): entity refs + all active scalars
relation total_count_entity_pred(String, String, i32);
total_count_entity_pred(x, p, c) <--
  entity_uses_pred(x, p),
  pred_is_entity_type(p),
  active_entity_ref_count(x, p, c);

total_count_entity_pred(x, p, 0) <--
  entity_uses_pred(x, p),
  pred_is_entity_type(p),
  !active_entity_ref(x, p, _, _);

relation total_count_scalar_pred(String, String, i32);
total_count_scalar_pred(x, p, c) <--
  entity_uses_pred(x, p),
  !pred_is_entity_type(p),
  active_scalar_count(x, p, c);

total_count_scalar_pred(x, p, 0) <--
  entity_uses_pred(x, p),
  !pred_is_entity_type(p),
  !active_scalar_stmt(x, p, _, _);

// cardinality_violation_min(entity, pred, card_min_str, real_count_str)
relation cardinality_violation_min(String, String, i32, i32);
cardinality_violation_min(x, p, mn, c) <--
  predicate_def(p, _, mn, _, _, _), if mn > 0,
  real_count_entity_pred(x, p, c), if c < mn;
cardinality_violation_min(x, p, mn, c) <--
  predicate_def(p, _, mn, _, _, _), if mn > 0,
  real_count_scalar_pred(x, p, c), if c < mn;

// cardinality_violation_max(entity, pred, card_max_str, total_count_str)
relation cardinality_violation_max(String, String, i32, i32);
cardinality_violation_max(x, p, mx, c) <--
  predicate_def(p, _, _, mx, _, _), if mx >= 0,
  total_count_entity_pred(x, p, c), if c > mx;
cardinality_violation_max(x, p, mx, c) <--
  predicate_def(p, _, _, mx, _, _), if mx >= 0,
  total_count_scalar_pred(x, p, c), if c > mx;

// ── Violation: deprecated_no_end_time ────────────────────────────────────────
// Deprecated statement without an end_time qualifier.
// rank_idx for deprecated statements starts with "deprecated\0"

relation has_end_time(String, String, String);
has_end_time(x, p, rk) <-- has_qualifier(x, p, rk, "end_time");

relation deprecated_no_end_time(String, String);
deprecated_no_end_time(x, p) <--
  stmt_rank(x, p, rk, "deprecated"),
  !has_end_time(x, p, rk);

// ── Violation: end_without_start ─────────────────────────────────────────────
// Non-deprecated, non-sentinel statement with end_time but no start_time.

relation end_without_start(String, String);
end_without_start(x, p) <--
  stmt_rank(x, p, rk, rank), if rank != "deprecated",
  has_qualifier(x, p, rk, "end_time"),
  !has_qualifier(x, p, rk, "start_time"),
  // Exclude sentinel stmts (is_sentinel tracks them)
  !is_sentinel(x, p, rk);

// ── Violation: source_required_violation ─────────────────────────────────────
// Owner lens requires sources, but a non-deprecated non-structural statement has none.
// Structural: instance_of and subclass_of on class entities are exempt.

relation source_required_violation(String, String);
// For non-class entities: any predicate without source
source_required_violation(x, p) <--
  stmt_rank(x, p, rk, rank), if rank != "deprecated",
  entity_owner(x, owner, "true"),
  !stmt_src(x, p, rank, _),
  !is_class(x);

// For class entities: only non-structural predicates
source_required_violation(x, p) <--
  stmt_rank(x, p, rk, rank), if rank != "deprecated",
  entity_owner(x, owner, "true"),
  !stmt_src(x, p, rank, _),
  is_class(x),
  if p != "instance_of",
  if p != "subclass_of";

// ── Violation: cross_lens_fictional ──────────────────────────────────────────
// Factual lens references an entity owned by a fictional or interpretive lens.

relation entity_owner_register(String, String);
entity_owner_register(x, reg) <-- entity_owner(x, owner, _), lens(owner, reg, _);

relation cross_lens_fictional(String, String, String);
// subject_entity, predicate, owner_lens_of_target
cross_lens_fictional(x, p, ref_owner) <--
  entity_ref(x, p, t, rank), if rank != "deprecated",
  entity_owner_register(x, "factual"),
  entity_owner(t, ref_owner, _),
  lens(ref_owner, ref_reg, _),
  if ref_reg == "fictional" || ref_reg == "interpretive";

// ── Violation: qualifier_unknown_predicate ────────────────────────────────────
// A qualifier key is not a defined predicate.

relation known_predicate(String);
known_predicate(p) <-- predicate_def(p, _, _, _, _, _);

relation qualifier_unknown_predicate(String, String, String);
qualifier_unknown_predicate(x, p, qp) <--
  has_qualifier(x, p, _, qp),
  !known_predicate(qp);

// ── Violation: qualifier_dangling_ref ────────────────────────────────────────
// An entity-ref qualifier points to an entity that doesn't exist.

relation qualifier_dangling_ref(String, String, String);
qualifier_dangling_ref(x, p, t) <--
  qualifier_entity_ref(x, p, _, _, t),
  !entity(t, _);

// ── Violation: alias_self_reference ──────────────────────────────────────────
// A predicate's alias_of points to itself.

relation alias_self_reference(String);
alias_self_reference(p) <-- predicate_alias(p, p);

// ── Violation: alias_cycle ────────────────────────────────────────────────────
// An alias_of chain forms a cycle.

relation alias_reachable(String, String);
alias_reachable(a, b) <-- predicate_alias(a, b);
alias_reachable(a, c) <-- predicate_alias(a, b), alias_reachable(b, c);

relation alias_cycle(String);
alias_cycle(p) <-- alias_reachable(p, p);
